{
  "permissions": {
    "allow": [
      "mcp__gitnexus",
      "mcp__gitnexus__*",
      "Bash(npx gitnexus:*)",
      "Bash(npx gitnexus *)",
      "Bash(gitnexus:*)",
      "Bash(npm i -g gitnexus)",
      "Bash(node .gitnexus/run.cjs:*)",
      "Bash(node .gitnexus/*)",
      "Read(.gitnexus/**)",
      "Read(//.gitnexus/**)"
    ],
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },
  "mcpServers": {
    "gitnexus": {
      "command": "npx",
      "args": [
        "-y",
        "gitnexus",
        "mcp"
      ]
    }
  }
}

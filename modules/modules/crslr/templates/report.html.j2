<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ title }}</title>
<style>
body { font-family: 'Georgia', serif; max-width: 800px; margin: 0 auto; padding: 2em; color: #333; }
h1 { color: #111; border-bottom: 2px solid #333; padding-bottom: 0.3em; }
h2 { color: #444; margin-top: 1.5em; }
table { border-collapse: collapse; width: 100%; margin: 1em 0; }
th, td { border: 1px solid #ccc; padding: 0.5em; text-align: left; }
th { background: #f5f5f5; }
.badge-pass { display: inline-block; background: #28a745; color: #fff; padding: 0.2em 0.6em; border-radius: 4px; font-weight: bold; }
.badge-fail { display: inline-block; background: #dc3545; color: #fff; padding: 0.2em 0.6em; border-radius: 4px; font-weight: bold; }
.badge-pending { display: inline-block; background: #ffc107; color: #333; padding: 0.2em 0.6em; border-radius: 4px; font-weight: bold; }
.footer { text-align: center; color: #999; font-size: 0.8em; margin-top: 3em; border-top: 1px solid #ddd; padding-top: 1em; }
.katex { font-size: 1.1em; }
@media print { body { font-size: 11pt; } }
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16/dist/katex.min.css">
</head>
<body>

<h1>{{ title }}</h1>

<p>
<strong>Analysis ID:</strong> <code>{{ analysis_id }}</code><br>
<strong>Date:</strong> {{ date }}<br>
<strong>Domain:</strong> {{ domain }}<br>
<strong>VVV Status:</strong>
{% if vvv_status == "PASS" %}
<span class="badge-pass">PASS</span>
{% elif vvv_status == "FAIL" %}
<span class="badge-fail">FAIL</span>
{% else %}
<span class="badge-pending">{{ vvv_status }}</span>
{% endif %}
<br>
<strong>Uncertainty Interval:</strong> {{ uncertainty_interval }}
</p>

{% for section_id in ["context", "results", "synthesis", "limitations", "recommendations"] %}
{% set section = sections.get(section_id) %}
{% if section %}
<h2>{{ section_id | title }}</h2>

<p>{{ section.content }}</p>

{% if section_id == "results" and section.metrics %}
<table>
<thead>
<tr><th>Metric</th><th>Value</th><th>Uncertainty ({{ uncertainty_interval }})</th></tr>
</thead>
<tbody>
{% for key, val in section.metrics.items() %}
<tr><td>{{ key }}</td><td>{{ val.value }}</td><td>± {{ val.uncertainty }}</td></tr>
{% endfor %}
</tbody>
</table>
{% endif %}
{% endif %}
{% endfor %}

<h2>References</h2>
<ol>
{% for ref in references %}
<li>{{ ref }}</li>
{% else %}
<li>No references provided.</li>
{% endfor %}
</ol>

<div class="footer">Generated by CRSLR Engine • M9 Compliant • {{ date }}</div>

<script src="https://cdn.jsdelivr.net/npm/katex@0.16/dist/katex.min.js"></script>
</body>
</html>
